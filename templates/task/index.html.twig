{% extends 'base.html.twig' %}

{% block title %}My Tasks{% endblock %}

{% block body %}
    <h1>My Tasks</h1>

    <p><a href="{{ path('task_new') }}">New task</a></p>

    <ul>
        {% for task in tasks %}
            <li>
                <a href="{{ path('task_details', {'id': task.id}) }}">
                    [ {{ task.id }} ]
                    {% if task.done %}
                        <s>{{ task.title }}</s>
                    {% else %}
                        {{ task.title }}
                    {% endif %}
                </a>
            </li>
        {% else %}
            <li>No tasks yet.</li>
        {% endfor %}
    </ul>
{% endblock %}
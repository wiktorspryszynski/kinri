{% extends 'base.html.twig' %}

{% block title %}Tasks{% endblock %}

{% block body %}
    <h1>Tasks</h1>

    <ul>
        {% for task in tasks %}
            <li>
                <a href="{{ path('task_details', {'id': task.id}) }}">
                    [ {{ task.id }} ]
                    {% if task.done %}
                        <s>{{ task.title }}</s>
                    {% else %}
                        {{ task.title }}
                    {% endif %}
                </a>
                {% if task.assignee %}
                    — {{ task.assignee.name }}
                {% else %}
                    — <em>Unassigned</em>
                {% endif %}
            </li>
        {% else %}
            <li>No tasks yet.</li>
        {% endfor %}
    </ul>
{% endblock %}